#include <winver.h>

1 ICON "app.ico"

1 24 "app.manifest"

VS_VERSION_INFO VERSIONINFO
    FILEVERSION    RC_VERSION_NUM
    PRODUCTVERSION RC_VERSION_NUM
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
    FILEFLAGS      0
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_APP
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      RC_COMPANY
            VALUE "FileDescription",  RC_DESCRIPTION
            VALUE "FileVersion",      RC_VERSION_STR
            VALUE "InternalName",     "wsconfig"
            VALUE "LegalCopyright",   "Copyright (c) 2025 " RC_COMPANY
            VALUE "OriginalFilename", RC_FILENAME
            VALUE "ProductName",      RC_PRODUCT
            VALUE "ProductVersion",   RC_VERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END

STRINGTABLE
{
    1, "Workspace Configuration"
    2, "Loading workspace profile..."
    3, "Profile applied."
    4, "Endpoint unreachable. Check network settings."
    5, "Workspace Settings"
    6, "Contoso Workspace Tools"
    7, "Close"
    8, "Applying workspace profile..."
    9, "A newer profile is available."
    10, "Sync Now"
    11, "Options"
    12, "Apply"
    13, "Reset to Defaults"
    14, "Export Profile..."
    15, "Import Profile..."
    16, "Workspace connected."
    17, "Validating environment..."
    18, "Idle."
    19, "Done."
    20, "Retry"
}

STRINGTABLE
{
    100, "Workspace"
    101, "Connectivity"
    102, "Appearance"
    103, "Alerts"
    104, "Compliance"
    105, "Data Handling"
    106, "Disk Usage"
    107, "Identity"
    108, "Locale"
    109, "Clock"
    110, "Input"
    111, "Pointing Devices"
    112, "Audio"
    113, "Wireless"
    114, "Print Services"
    115, "Power Management"
    116, "Autostart"
    117, "File Associations"
    118, "Ease of Access"
    119, "Device Information"
}

100 DIALOG 0, 0, 280, 220
STYLE 0x80C80000
CAPTION "Workspace Configuration"
{
    LTEXT           "Profile:", -1, 10, 14, 55, 10
    EDITTEXT        101, 70, 12, 200, 14, 0x50010080
    LTEXT           "Endpoint:", -1, 10, 34, 55, 10
    EDITTEXT        102, 70, 32, 200, 14, 0x50010080
    GROUPBOX        "Workspace Options", -1, 10, 54, 260, 90
    AUTOCHECKBOX    "Enable alerts", 104, 20, 68, 100, 14
    AUTOCHECKBOX    "Launch at logon", 105, 20, 84, 100, 14
    AUTOCHECKBOX    "Run in background", 106, 20, 100, 110, 14
    AUTOCHECKBOX    "Sync on metered connections", 107, 20, 116, 140, 14
    PUSHBUTTON      "Cancel", 2, 160, 195, 50, 14
    DEFPUSHBUTTON   "Apply", 1, 216, 195, 50, 14
}

200 MENU
{
    POPUP "&Workspace"
    {
        MENUITEM "&Options...\tCtrl+O", 40001
        MENUITEM SEPARATOR
        MENUITEM "&Import Profile...", 40002
        MENUITEM "&Export Profile...", 40003
        MENUITEM SEPARATOR
        MENUITEM "&Close\tAlt+F4", 40005
    }
    POPUP "&Tools"
    {
        MENUITEM "&Sync Now\tF5", 40201
        MENUITEM "&Event Log", 40202
        MENUITEM SEPARATOR
        MENUITEM "&Diagnostics...", 40204
    }
    POPUP "&Help"
    {
        MENUITEM "&Documentation\tF1", 40401
        MENUITEM "&Check for Updates...", 40403
        MENUITEM SEPARATOR
        MENUITEM "&About Workspace Tools", 40405
    }
}
